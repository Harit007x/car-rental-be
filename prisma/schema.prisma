// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum AdminStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum RoleStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum GovernmentUserStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum SubscriptionStatus {
  ENABLED
  DISABLED
  DELETED
}

enum BusinessType {
  INDIVIDUAL
  COMPANY
  FLEET_OPERATOR
}

enum CompanyStatus {
  INACTIVE
  ACTIVE
  ACCOUNT_DELETED
}

enum TokenStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum AuthUserType {
  ADMIN
  GOVERNMENT
}

model Admin {
  id                 String            @id @default(uuid())
  name               String
  email              String            @unique
  passwordHash       String
  isSuperAdmin       Boolean           @default(false)
  roleId             String?
  role               Role?             @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissions        AdminPermission[]
  status             AdminStatus       @default(ACTIVE)
  mustChangePassword Boolean           @default(true)
  deletedAt          DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([roleId])
  @@index([status])
  @@index([isSuperAdmin])
  @@index([deletedAt])
}

model Module {
  id               String            @id @default(uuid())
  key              String            @unique
  name             String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  adminPermissions AdminPermission[]
  rolePermissions  RolePermission[]
}

model Role {
  id          String           @id @default(uuid())
  name        String
  status      RoleStatus       @default(ACTIVE)
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  admins      Admin[]
  permissions RolePermission[]

  @@index([status])
  @@index([deletedAt])
}

model RolePermission {
  id        String   @id @default(uuid())
  roleId    String
  moduleId  String
  canView   Boolean  @default(false)
  canAdd    Boolean  @default(false)
  canEdit   Boolean  @default(false)
  canDelete Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleId])
  @@index([moduleId])
  @@index([roleId])
}

model AdminPermission {
  id        String   @id @default(uuid())
  adminId   String
  moduleId  String
  canView   Boolean  @default(false)
  canAdd    Boolean  @default(false)
  canEdit   Boolean  @default(false)
  canDelete Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([adminId, moduleId])
  @@index([moduleId])
  @@index([adminId])
}

model GovernmentUser {
  id                 String               @id @default(uuid())
  name               String
  mobile             String               @unique
  email              String               @unique
  address            String?
  passwordHash       String
  status             GovernmentUserStatus @default(ACTIVE)
  mustChangePassword Boolean              @default(true)
  deletedAt          DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([status])
  @@index([deletedAt])
  @@index([createdAt])
}

model RefreshToken {
  id        String       @id @default(uuid())
  userId    String
  userType  AuthUserType
  tokenHash String       @unique
  status    TokenStatus  @default(ACTIVE)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([userId, userType])
  @@index([status])
  @@index([expiresAt])
}

model ResetPasswordToken {
  id        String       @id @default(uuid())
  userId    String
  userType  AuthUserType
  tokenHash String       @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime     @default(now())

  @@index([userId, userType])
  @@index([expiresAt])
}

model Feature {
  id                   String                @id @default(uuid())
  key                  String                @unique
  name                 String
  description          String?
  subscriptionFeatures SubscriptionFeature[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model Subscription {
  id                   String                @id @default(uuid())
  name                 String                @unique
  description          String
  price                Decimal               @db.Decimal(10, 2)
  status               SubscriptionStatus    @default(ENABLED)
  deletedAt            DateTime?
  subscriptionFeatures SubscriptionFeature[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([status])
  @@index([deletedAt])
}

model SubscriptionFeature {
  subscriptionId String
  featureId      String
  order          Int          @default(0)
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  feature        Feature      @relation(fields: [featureId], references: [id], onDelete: Restrict)

  @@id([subscriptionId, featureId])
  @@index([featureId])
}

model CmsPage {
  id        String   @id @default(uuid())
  title     String
  slug      String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tenant {
  id                 String        @id @default(uuid())
  subdomain          String        @unique
  businessName       String
  registrationNumber String
  ownerName          String
  ownerPhone         String
  ownerEmail         String
  businessAddress    String
  city               String
  state              String
  country            String
  businessType       BusinessType
  fleetSize          Int
  bankAccount        BankAccount?
  status             CompanyStatus @default(INACTIVE)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model BankAccount {
  id          String   @id @default(uuid())
  tenantId    String   @unique
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  accountName String
  accountNo   String
  bankName    String
  ifscCode    String
  createdAt   DateTime @default(now())
}
