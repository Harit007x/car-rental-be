// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum AdminRole {
  SUPER_ADMIN
  GOVERNMENT_ADMIN
}

enum BusinessType {
  INDIVIDUAL
  COMPANY
  FLEET_OPERATOR
}

// ─── Global Models (public schema) ───────────────────────

model AdminUser {
  id            String              @id @default(uuid())
  email         String              @unique
  password      String
  role          AdminRole
  refreshTokens AdminRefreshToken[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}

model AdminRefreshToken {
  id          String    @id @default(uuid())
  adminUserId String
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id])
  tokenId     String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([adminUserId])
}

model Tenant {
  id                 String            @id @default(uuid())
  subdomain          String            @unique // e.g. abc.yourapp.com
  businessName       String
  registrationNumber String
  ownerName          String
  ownerPhone         String
  ownerEmail         String
  businessAddress    String
  city               String
  state              String
  country            String
  businessType       BusinessType
  fleetSize          Int
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  driverDirectories  DriverDirectory[]
}

model DriverDirectory {
  id        String   @id @default(uuid())
  mobile    String   @unique
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model Otp {
  id        String   @id @default(uuid())
  mobile    String
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([mobile])
}
