// Tenant-scoped Prisma schema
// Tables created per tenant in their own PostgreSQL schema (tenant_<id>)
// No tenantId needed — schema isolation provides tenant separation

generator tenantClient {
  provider = "prisma-client"
  output   = "../src/generated/prisma-tenant"
}

datasource tenantDb {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────
enum Role {
  RENTAL_ADMIN
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum DeliveryPartnerStatus {
  ACTIVE
  INACTIVE
  ACCOUNT_DELETED
}

enum PartnerDocumentType {
  DRIVING_LICENSE
}

enum CustomerDocumentType {
  DRIVING_LICENSE
  SIGNED_CONTRACT
}

// ─── MODELS ─────────────────────────────────────────────

// Rental Admin (Web Login)
model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  password           String
  role               Role           @default(RENTAL_ADMIN)
  mustChangePassword Boolean        @default(true)
  isEmailVerified    Boolean        @default(false)
  refreshTokens      RefreshToken[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  tokenId   String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
}

model DeliveryPartner {
  id        String                    @id @default(uuid())
  name      String
  phone     String                    @unique
  email     String?
  address   String
  dob       DateTime?
  status    DeliveryPartnerStatus     @default(ACTIVE)
  documents DeliveryPartnerDocument[]
  createdAt DateTime                  @default(now())
}

model DeliveryPartnerDocument {
  id         String              @id @default(uuid())
  partnerId  String
  partner    DeliveryPartner     @relation(fields: [partnerId], references: [id])
  type       PartnerDocumentType
  fileUrl    String
  uploadedAt DateTime            @default(now())

  @@index([partnerId])
}

model Customer {
  id                String             @id @default(uuid())
  name              String
  mobileNumber      String
  email             String?
  address           String
  status            CustomerStatus     @default(ACTIVE)
  createdAt         DateTime           @default(now())
  customerDocuments CustomerDocument[]
}

model CustomerDocument {
  id         String               @id @default(uuid())
  customerId String
  customer   Customer             @relation(fields: [customerId], references: [id])
  type       CustomerDocumentType
  fileUrl    String
  uploadedAt DateTime             @default(now())

  @@index([customerId])
}

model ServiceLocation {
  id        String   @id @default(uuid())
  city      String
  state     String
  country   String
  createdAt DateTime @default(now())
}
